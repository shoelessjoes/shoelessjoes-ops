DATABASE_URL=postgresql://user:pass@localhost:5432/dealernet_ops

SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2024-10

DEALERNET_USERNAME=
DEALERNET_PASSWORD=

# SMTP for alerts (same semantics as Python ALERT_*)
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USERNAME=
ALERT_SMTP_PASSWORD=
ALERT_SMTP_STARTTLS=true
ALERT_FROM_EMAIL=
ALERT_TO_EMAILS=
ALERT_SMS_EMAILS=

# Set to 1 on first import to store messages without sending notifications for backlog.
DEALERNET_POLL_BOOTSTRAP=
# Optional; must include https:// if set. Default: https://www.dealernetx.com/inbox.php
DEALERNET_INBOX_URL=

# Zhongda Cloud vending portal (https://us.zhongdacloud.com)
ZHONGDA_USERNAME=
ZHONGDA_PASSWORD=
# ZHONGDA_SLOW_MO_MS=150

# Sealed catalog (required for export-catalog + pricing)
# CATALOG_PRODUCT_TYPES=Sealed Wax - Baseball,Sealed Wax - Basketball
# CATALOG_CSV_PATH=data/sealed-catalog.csv

# Vending price check (job:vending-price-check)
# VENDING_REPORT_IN_STOCK_ONLY=1
# VENDING_PRICE_CHECK_EMAIL=1
